---
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "Fleet Manager — Real-time dispatch for school transportation",
  description = "The dispatch system school transportation runs on. Replace spreadsheets and radios with one live board your whole office shares.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
