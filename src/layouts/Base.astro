---
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "Fleet Manager — Real-time dispatch for school transportation",
  description = "The dispatch system school transportation runs on. Replace spreadsheets and radios with one live board your whole office shares.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <script is:inline>
    // Set early so the .reveal CSS rule activates before first paint, avoiding FOUC.
    document.documentElement.classList.add("js");
  </script>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      // Reveal targets: those near or above the fold fade in immediately on load;
      // ones further below get progressively-staggered reveals as they enter the
      // viewport. Robust to fullpage screenshots and SEO crawlers (CSS gates on
      // html.js, which we set via the inline boot script).
      const targets = document.querySelectorAll<HTMLElement>(".reveal");
      if (targets.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            }
          },
          // Generous bottom rootMargin so elements just-below-the-fold are caught
          // on initial pass — prevents long blank stretches before user scrolls.
          { rootMargin: "0px 0px 25% 0px", threshold: 0 }
        );
        targets.forEach((el) => io.observe(el));

        // Safety net: anything not yet revealed after 1s gets revealed anyway.
        // Covers tools that snapshot the DOM without scrolling.
        window.setTimeout(() => {
          targets.forEach((el) => el.classList.add("is-visible"));
        }, 1000);
      }
    </script>
  </body>
</html>
