---
type Props = {
  glyph: "device" | "alert" | "sunrise";
  size: number;
  stroke: string;
};
const { glyph, size, stroke } = Astro.props;
const dim = `${size}px`;
---
{glyph === "device" && (
  <svg viewBox="0 0 64 64" fill="none" stroke={stroke} stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="relative" style={`width: ${dim}; height: ${dim};`}>
    {/* Tablet outline */}
    <rect x="14" y="10" width="36" height="44" rx="4" opacity="0.95" />
    {/* Inner screen lines (status, table) */}
    <line x1="20" y1="18" x2="44" y2="18" opacity="0.55" />
    <line x1="20" y1="24" x2="36" y2="24" opacity="0.4" />
    <rect x="20" y="30" width="24" height="12" rx="1.5" opacity="0.65" />
    {/* Bottom signal pulse — connects driver app to dispatcher */}
    <circle cx="32" cy="50" r="1.6" fill={stroke} stroke="none" />
    {/* Wireless arc above */}
    <path d="M22 6 Q32 2 42 6" opacity="0.6" />
    <path d="M26 4 Q32 1 38 4" opacity="0.35" />
  </svg>
)}
{glyph === "alert" && (
  <svg viewBox="0 0 64 64" fill="none" stroke={stroke} stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="relative" style={`width: ${dim}; height: ${dim};`}>
    {/* Bell silhouette */}
    <path d="M22 38 Q22 22 32 22 Q42 22 42 38 L46 44 H18 Z" opacity="0.85" />
    <path d="M28 48 Q28 52 32 52 Q36 52 36 48" opacity="0.7" />
    {/* Stem at top */}
    <path d="M32 18 V22" opacity="0.65" />
    {/* Calendar grid in background — alerts know your calendar */}
    <rect x="6" y="8" width="14" height="11" rx="1.5" opacity="0.35" />
    <line x1="6" y1="12" x2="20" y2="12" opacity="0.3" />
    <line x1="10" y1="8" x2="10" y2="11" opacity="0.3" />
    <line x1="16" y1="8" x2="16" y2="11" opacity="0.3" />
    {/* Soundwave arcs */}
    <path d="M48 28 Q52 32 48 36" opacity="0.45" />
    <path d="M52 24 Q58 32 52 40" opacity="0.25" />
  </svg>
)}
{glyph === "sunrise" && (
  <svg viewBox="0 0 64 64" fill="none" stroke={stroke} stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="relative" style={`width: ${dim}; height: ${dim};`}>
    {/* Half-sun rising over horizon */}
    <path d="M16 44 A16 16 0 0 1 48 44" opacity="0.95" />
    {/* Horizon line */}
    <line x1="6" y1="44" x2="58" y2="44" opacity="0.85" />
    {/* Below-horizon faded marks (data already pre-arranged) */}
    <line x1="14" y1="50" x2="50" y2="50" opacity="0.35" />
    <line x1="20" y1="55" x2="44" y2="55" opacity="0.18" />
    {/* Rays */}
    <line x1="32" y1="22" x2="32" y2="14" opacity="0.6" />
    <line x1="20" y1="28" x2="14" y2="22" opacity="0.45" />
    <line x1="44" y1="28" x2="50" y2="22" opacity="0.45" />
    <line x1="11" y1="40" x2="4" y2="40" opacity="0.4" />
    <line x1="53" y1="40" x2="60" y2="40" opacity="0.4" />
  </svg>
)}
