---
// Note: testimonial copy below is illustrative for layout. Replace with verified
// quotes from Karl/Kathy at Northline before launch.
const featured = {
  quote: "Used to be a whiteboard, a spreadsheet, and three phone calls. Now it's one screen the whole office watches.",
  name: "Operations manager",
  role: "Northline Transportation",
  bg: "var(--color-accent-2)",
  fg: "#0a2e1a",
  initial: "K",
};
const secondary = {
  quote: "I can see who's checked in without leaving my chair. The 5 AM rush isn't quiet, but it's a lot less loud.",
  name: "AM dispatcher",
  role: "Type III school transportation",
  bg: "#f4eedd",
  fg: "#1a1814",
  initial: "K",
};
---
<section id="customers" class="border-b border-[var(--color-border)] bg-[var(--color-bg)]">
  <div class="mx-auto max-w-[1180px] px-6 py-16 md:py-24">
    <div class="mb-7 flex items-end justify-between md:mb-10">
      <a href="#customers" class="text-[13px] text-[var(--color-muted)] hover:text-[var(--color-fg)]">View all →</a>
    </div>

    <div class="grid grid-cols-[1.86fr_1fr] gap-2 md:gap-4">
      <!-- Featured (lead) testimonial -->
      <figure
        class="flex min-h-[200px] flex-col justify-between rounded-[12px] p-5 md:min-h-[420px] md:rounded-[20px] md:p-12"
        style={`background: ${featured.bg}; color: ${featured.fg};`}
      >
        <blockquote class="text-[18px] font-medium leading-[1.18] tracking-[-0.015em] md:text-[34px] md:leading-[1.15]">
          “{featured.quote}”
        </blockquote>
        <figcaption class="mt-5 flex items-center gap-2 text-[12px] md:mt-10 md:gap-3 md:text-[14px]">
          <span class="grid h-7 w-7 place-items-center rounded-full bg-black/15 font-semibold md:h-10 md:w-10">
            {featured.initial}
          </span>
          <span class="min-w-0">
            <div class="truncate font-semibold">{featured.name}</div>
            <div class="truncate opacity-75">{featured.role}</div>
          </span>
        </figcaption>
      </figure>

      <!-- Secondary -->
      <figure
        class="flex min-h-[200px] flex-col justify-between rounded-[12px] p-4 md:min-h-[420px] md:rounded-[20px] md:p-8"
        style={`background: ${secondary.bg}; color: ${secondary.fg};`}
      >
        <blockquote class="text-[14px] font-medium leading-[1.22] tracking-[-0.01em] md:text-[22px] md:leading-[1.2]">
          “{secondary.quote}”
        </blockquote>
        <figcaption class="mt-4 flex items-center gap-2 text-[11px] md:mt-8 md:gap-3 md:text-[13px]">
          <span class="grid h-6 w-6 place-items-center rounded-full bg-black/15 font-semibold md:h-9 md:w-9">
            {secondary.initial}
          </span>
          <span class="min-w-0">
            <div class="truncate font-semibold">{secondary.name}</div>
            <div class="truncate opacity-75">{secondary.role}</div>
          </span>
        </figcaption>
      </figure>
    </div>

    <div class="mt-5 flex flex-col gap-1 text-[12px] text-[var(--color-muted)] md:mt-7 md:flex-row md:items-center md:justify-between">
      <span>Built with Northline Transportation as our anchor customer. More to come.</span>
      <a href="#customers" class="hover:text-[var(--color-fg)]">Customer stories →</a>
    </div>
  </div>
</section>
