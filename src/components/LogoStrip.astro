---
const logos = [
  { name: "Northline", style: "font-bold tracking-tight" },
  { name: "Districts", style: "italic tracking-tight" },
  { name: "Operators", style: "font-light tracking-[0.2em] uppercase" },
  { name: "Fleets", style: "font-mono uppercase" },
  { name: "Shifts", style: "font-semibold tracking-tighter" },
  { name: "Routes", style: "tracking-wide uppercase" },
];
---
<section class="border-b border-[var(--color-border)] bg-[var(--color-bg)]">
  <div class="mx-auto max-w-[1180px] px-6 py-10">
    <div class="logo-strip flex flex-wrap items-center justify-center gap-x-12 gap-y-5 text-[18px] text-[var(--color-fg-dim)] md:flex-nowrap md:justify-between">
      {logos.map((l) => (
        <span class={l.style}>{l.name}</span>
      ))}
    </div>
  </div>
</section>
