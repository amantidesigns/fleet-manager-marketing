---
// Placeholder marks until we land real customer logos.
// Uniform weight + tracking keeps the row quiet — no false "designed" brand variety.
const marks = [
  "Northline Transportation",
  "Type III · MN",
  "Coverage districts",
  "Early access cohort",
  "Spring 2026",
];
---
<section class="border-b border-[var(--color-border)] bg-[var(--color-bg)]">
  <div class="mx-auto max-w-[1180px] px-6 py-12">
    <div class="mb-7 flex items-center justify-center">
      <span class="section-label">Trusted by small fleets that move people</span>
    </div>
    <div class="logo-strip flex flex-wrap items-center justify-center gap-x-12 gap-y-4 md:flex-nowrap md:justify-between">
      {marks.map((m) => (
        <span class="font-mono text-[12px] uppercase tracking-[0.16em] text-[var(--color-fg-dim)]">
          {m}
        </span>
      ))}
    </div>
  </div>
</section>
