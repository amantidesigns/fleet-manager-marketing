---
// Placeholder marks until we land real customer logos.
// Uniform weight + tracking keeps the row quiet — no false "designed" brand variety.
const marks = [
  "Type III · MN",
  "5 districts",
  "56 routes",
  "100 vans",
  "Spring 2026",
];
---
<section class="border-b border-[var(--color-border)] bg-[var(--color-bg)]">
  <div class="mx-auto max-w-[1180px] px-6 py-8 md:py-12">
    <div class="mb-5 flex items-center justify-center md:mb-7">
      <span class="section-label">What Northline Transportation runs on</span>
    </div>
    <div class="logo-strip flex flex-wrap items-center justify-center gap-x-5 gap-y-3 md:flex-nowrap md:justify-between md:gap-x-12 md:gap-y-4">
      {marks.map((m) => (
        <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-fg-dim)] md:text-[12px] md:tracking-[0.16em]">
          {m}
        </span>
      ))}
    </div>
  </div>
</section>
