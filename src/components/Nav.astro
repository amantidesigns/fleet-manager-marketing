---
import Logo from "./Logo.astro";
const APP_URL = "https://northline-dashboard.vercel.app";
---
<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/70 backdrop-blur-md">
  <div class="mx-auto flex h-14 max-w-[1180px] items-center justify-between px-6">
    <a href="/" class="text-[var(--color-fg)] no-underline">
      <Logo size={20} />
    </a>

    <nav class="hidden items-center gap-7 text-[13px] text-[var(--color-muted)] md:flex">
      <a href="#product" class="hover:text-[var(--color-fg)]">Product</a>
      <a href="#customers" class="hover:text-[var(--color-fg)]">Customers</a>
      <a href="#pricing" class="hover:text-[var(--color-fg)]">Pricing</a>
      <a href="#changelog" class="hover:text-[var(--color-fg)]">Changelog</a>
    </nav>

    <div class="flex items-center gap-3 text-[13px]">
      <a href={APP_URL} class="text-[var(--color-muted)] hover:text-[var(--color-fg)]">Log in</a>
      <a
        href="#waitlist"
        class="rounded-full bg-[var(--color-fg)] px-3.5 py-1.5 font-medium text-[var(--color-bg)] transition hover:bg-white"
      >
        <span class="md:hidden">Get access</span>
        <span class="hidden md:inline">Sign up for early access</span>
      </a>
    </div>
  </div>
</header>
