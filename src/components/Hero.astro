---
import WaitlistForm from "./WaitlistForm.tsx";
import StatCard from "./product/StatCard.tsx";
import DispatchTable from "./product/DispatchTable.tsx";
import ActivityRow from "./product/ActivityRow.tsx";
---
<section class="hero-gradient relative overflow-hidden border-b border-[var(--color-border)]">
  <div class="mx-auto max-w-[1180px] px-6 pt-20 pb-16 md:pt-28 md:pb-20">
    <div class="stagger max-w-3xl">
      <span class="tag stagger-child" style="--idx: 0">Closed beta · School transportation</span>
      <h1 class="stagger-child mt-5 text-[34px] font-semibold leading-[1.05] tracking-[-0.03em] text-[var(--color-fg)] md:mt-6 md:text-[68px] md:leading-[1.02] md:tracking-[-0.035em]" style="--idx: 1">
        The dispatch system for small fleets and their drivers.
      </h1>
      <p class="stagger-child mt-5 max-w-xl text-[15px] leading-[1.55] text-[var(--color-muted)] md:mt-6 md:text-[16px]" style="--idx: 2">
        A real-time board for dispatchers and a tablet app for drivers, kept in sync from the first check-in to the last clear.
      </p>
      <div class="stagger-child mt-6 flex flex-col items-start gap-3 md:mt-7" id="waitlist" style="--idx: 3">
        <WaitlistForm client:load />
        <span class="text-[12px] text-[var(--color-muted-dim)]">
          New signups are limited while we work with our first customers.
        </span>
      </div>
    </div>

    <!-- Hero product card: a framed glassy preview that's actually live DOM -->
    <div class="stagger-child mt-10 md:mt-14" style="--idx: 4; --stagger-step: 90ms">
      <div class="relative">
        <div
          class="absolute -inset-x-12 -top-16 -bottom-16 -z-10 opacity-70 blur-3xl"
          style="background: radial-gradient(50% 50% at 50% 50%, rgba(46,134,193,0.45), transparent 70%);"
        ></div>
        <div class="glass overflow-hidden rounded-[16px] p-1 shadow-[0_50px_180px_-40px_rgba(0,0,0,0.85),0_0_0_1px_rgba(255,255,255,0.04)]">
          <div class="rounded-[12px] border border-[var(--color-border-2)] bg-[var(--color-bg-2)]">
            <!-- App header: clean native-app frame, no browser chrome -->
            <div class="flex items-center justify-between border-b border-[var(--color-border)] px-3 py-2 md:px-5 md:py-3">
              <div class="flex items-center gap-2 md:gap-3">
                <span class="section-label">Operations</span>
                <span class="hidden text-[11px] text-[var(--color-muted-dim)] sm:inline">·</span>
                <span class="hidden text-[12px] text-[var(--color-muted)] sm:inline">AM Shift · Mon Apr 30</span>
              </div>
              <div class="flex items-center gap-2 font-mono text-[11px] text-[var(--color-muted-dim)]">
                <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-[var(--color-ok)]"></span>
                Live · 5:42 AM
              </div>
            </div>

            <!-- App body -->
            <div class="grid gap-3 p-3 md:gap-5 md:p-6 md:grid-cols-[0.9fr_1.7fr_1.1fr]">
              <!-- Left: stats column -->
              <div class="flex flex-col gap-3">
                <StatCard client:load label="Coverage" value={94} unit="%" delta={{ value: "2 pts", positive: true }} hero />
                <StatCard client:load label="Routes assigned" value={56} delta={{ value: "1", positive: true }} />
                <StatCard client:load label="Open" value={3} delta={{ value: "1", positive: false }} />
              </div>

              <!-- Center: dispatch table (visually dominant column) -->
              <DispatchTable client:load />

              <!-- Right: activity -->
              <div class="rounded-[10px] border border-[var(--color-border)] bg-[var(--color-surface)] p-4">
                <div class="section-label mb-3">Activity</div>
                <ActivityRow client:load who="Kathy" what="checked in V-114" category="status" time="2 min ago" />
                <ActivityRow client:load who="Janelle" what="called in — relay to Marcus" category="alert" time="3 min ago" pulsing />
                <ActivityRow client:load who="Marcus" what="assigned WBL-21 standby" category="assignment" time="3 min ago" />
                <ActivityRow client:load who="Devin" what="pre-trip passed" category="inspection" time="6 min ago" />
                <ActivityRow client:load who="Karl" what="approved swap" category="note" time="9 min ago" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
