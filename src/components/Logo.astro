---
type Props = { size?: number };
const { size = 22 } = Astro.props;
---
<span class="inline-flex items-center gap-2 font-semibold tracking-tight" style={`font-size: ${size}px`}>
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true">
    <rect width="32" height="32" rx="7" fill="#0A0A0B" stroke="rgba(255,255,255,0.10)"/>
    <path d="M9 22 V10 L16 18 L23 10 V22" stroke="#2E86C1" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  <span>Fleet Manager</span>
</span>
