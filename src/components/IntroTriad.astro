---
const cards = [
  {
    label: "Built for dispatch",
    body: "Designed around the real job: drivers, routes, no-shows, coverage. Not bolted onto a generic CRM.",
    glyph: "stack" as const,
  },
  {
    label: "Powered by real-time",
    body: "Every keystroke syncs to every screen in the office in under 50ms. The whiteboard is finally live.",
    glyph: "pulse" as const,
  },
  {
    label: "Made for 5 AM",
    body: "OLED-friendly dark UI, oversized hit targets, keyboard-first flows. Built for cold mornings under pressure.",
    glyph: "sun" as const,
  },
];
---
<section class="border-b border-[var(--color-border)] bg-[var(--color-bg)]" id="product">
  <div class="mx-auto max-w-[1180px] px-6 py-24">
    <div class="max-w-3xl">
      <h2 class="text-[36px] font-semibold leading-[1.05] tracking-[-0.025em] md:text-[48px]">
        A new species of dispatch tool.
      </h2>
      <p class="mt-5 max-w-2xl text-[17px] leading-[1.55] text-[var(--color-muted)]">
        Purpose-built for small fleets that move people, not packages. Fleet Manager replaces three tools and a binder with one operating picture your whole office sees the same way.
      </p>
    </div>

    <div class="mt-14 grid gap-4 md:grid-cols-3">
      {cards.map((c) => (
        <div class="rounded-[14px] border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
          <div class="mb-6 grid h-28 place-items-center rounded-[10px] border border-[var(--color-border)] bg-[var(--color-bg-2)]">
            {c.glyph === "stack" && (
              <svg width="64" height="64" viewBox="0 0 64 64" fill="none" stroke="var(--color-accent)" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
                <path d="M32 14 L52 24 L32 34 L12 24 Z" />
                <path d="M12 32 L32 42 L52 32" opacity="0.65" />
                <path d="M12 40 L32 50 L52 40" opacity="0.35" />
              </svg>
            )}
            {c.glyph === "pulse" && (
              <svg width="64" height="64" viewBox="0 0 64 64" fill="none" stroke="var(--color-accent)" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="32" cy="32" r="20" opacity="0.35" />
                <circle cx="32" cy="32" r="12" opacity="0.65" />
                <path d="M14 32 H22 L26 24 L34 40 L38 32 H50" />
              </svg>
            )}
            {c.glyph === "sun" && (
              <svg width="64" height="64" viewBox="0 0 64 64" fill="none" stroke="var(--color-accent-2)" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="32" cy="40" r="10" />
                <path d="M22 40 H10 M54 40 H42 M32 30 V18 M16 24 L24 32 M48 24 L40 32" />
                <path d="M8 50 H56" opacity="0.4" />
              </svg>
            )}
          </div>
          <div class="text-[15px] font-semibold tracking-tight">{c.label}</div>
          <p class="mt-2 text-[13px] leading-relaxed text-[var(--color-muted)]">{c.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
