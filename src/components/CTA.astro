---
import WaitlistForm from "./WaitlistForm.tsx";
---
<section class="relative overflow-hidden border-b border-[var(--color-border)] bg-[var(--color-bg)]">
  <div
    class="pointer-events-none absolute inset-0 opacity-80"
    style="background:
      radial-gradient(60% 50% at 50% 0%, rgba(46,134,193,0.18), transparent 70%),
      radial-gradient(40% 40% at 50% 100%, rgba(46,204,113,0.06), transparent 70%);"
  ></div>
  <div class="relative mx-auto max-w-[1180px] px-6 py-40 text-center">
    <span class="tag mx-auto">Closed beta · Available today</span>
    <h2 class="mx-auto mt-7 max-w-3xl text-[44px] font-semibold leading-[1.02] tracking-[-0.035em] md:text-[68px]">
      Built for the way <br class="hidden md:inline" />small fleets actually run.
    </h2>
    <p class="mx-auto mt-6 max-w-xl text-[16px] leading-[1.55] text-[var(--color-muted)]">
      We're working with our first customers right now. If your office runs on spreadsheets and a radio, we want to talk.
    </p>
    <div class="mt-10 flex flex-col items-center gap-4">
      <WaitlistForm client:load compact />
      <a
        href="mailto:amantidesigns@gmail.com?subject=Fleet%20Manager%20%E2%80%94%20Contact%20sales"
        class="text-[13px] text-[var(--color-muted)] transition hover:text-[var(--color-fg)]"
      >
        Or contact sales →
      </a>
    </div>
  </div>
</section>
