---
const entries = [
  { tag: "Released", date: "Apr 23, 2026", title: "Standby auto-suggest", body: "When a driver calls in, eligible standbys surface automatically — sorted by district, then by recency." },
  { tag: "Released", date: "Apr 17, 2026", title: "55-inch optimized layout", body: "Density modes for wall-mounted office monitors. Every dispatcher sees the same grid from across the room." },
  { tag: "Beta", date: "Apr 09, 2026", title: "XLSX export", body: "One-click export of dispatch, fleet, or employee tables. Formatted for the people who still print." },
];
---
<section id="changelog" class="border-b border-[var(--color-border)] bg-[var(--color-bg)]">
  <div class="mx-auto max-w-[1180px] px-6 py-16 md:py-24">
    <div class="flex items-end justify-between">
      <div>
        <div class="section-label">Changelog</div>
        <h3 class="mt-3 text-[22px] font-semibold tracking-[-0.01em] md:text-[32px]">
          Shipping every week.
        </h3>
      </div>
      <a href="#changelog" class="text-[13px] text-[var(--color-muted)] hover:text-[var(--color-fg)]">
        See all →
      </a>
    </div>

    <div class="mt-8 grid gap-4 md:mt-10 md:grid-cols-3">
      {entries.map((e) => (
        <article class="rounded-[14px] border border-[var(--color-border)] bg-[var(--color-surface)] p-5">
          <div class="flex items-center justify-between">
            <span class="rounded-full border border-[var(--color-border-2)] px-2 py-0.5 text-[11px] uppercase tracking-wider text-[var(--color-accent)]">
              {e.tag}
            </span>
            <span class="font-mono text-[11px] text-[var(--color-muted-dim)]">{e.date}</span>
          </div>
          <h4 class="mt-4 text-[16px] font-semibold tracking-tight">{e.title}</h4>
          <p class="mt-2 text-[13px] leading-relaxed text-[var(--color-muted)]">{e.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
