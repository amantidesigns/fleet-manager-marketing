---
type Props = {
  eyebrow: string;
  title: string;
  body: string;
  reverse?: boolean;
};
const { eyebrow, title, body, reverse = false } = Astro.props;
---
<div class="reveal grid items-center gap-8 md:grid-cols-2 md:gap-16">
  <div class={reverse ? "md:order-2" : ""}>
    <div class="section-label">{eyebrow}</div>
    <h3 class="mt-3 text-[22px] font-semibold leading-tight tracking-[-0.01em] md:text-[34px]">
      {title}
    </h3>
    <p class="mt-3 max-w-md text-[14px] leading-relaxed text-[var(--color-muted)] md:mt-4 md:text-[15px]">{body}</p>
  </div>
  <div class={`relative ${reverse ? "md:order-1" : ""}`}>
    <div
      class="absolute -inset-6 -z-10 opacity-50 blur-3xl"
      style="background: radial-gradient(50% 50% at 50% 50%, rgba(46,134,193,0.18), transparent 70%);"
    ></div>
    <div class="glass overflow-hidden rounded-[14px] p-1">
      <div class="rounded-[12px] border border-[var(--color-border-2)] bg-[var(--color-bg-2)] p-4">
        <slot />
      </div>
    </div>
  </div>
</div>
