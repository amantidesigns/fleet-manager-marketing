---
import FeatureRow from "./FeatureRow.astro";
import DispatchTable from "./product/DispatchTable.tsx";
import RouteCard from "./product/RouteCard.tsx";
import CheckInGrid from "./product/CheckInGrid.tsx";
import ComplianceDiff from "./product/ComplianceDiff.tsx";
import DrawerPreview from "./product/DrawerPreview.tsx";
import DriverTablet from "./product/DriverTablet.tsx";
---
<section id="features" class="relative border-b border-[var(--color-border)] bg-[var(--color-bg)]">
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-[640px] -z-10 opacity-50"
    style="background: radial-gradient(80% 50% at 50% 0%, rgba(46,134,193,0.10), transparent 70%);"
  ></div>
  <div class="mx-auto max-w-[1180px] space-y-24 px-6 py-20 md:space-y-40 md:py-32">

    <FeatureRow
      eyebrow="Companion app"
      title="The board updates from the van itself."
      body="Every van has a tablet running our driver app, and that's where most of the morning happens now. Drivers run pre-trip with photos, check in, acknowledge relay notes, and clear routes from it, and every one of those actions lands on the dispatcher's screen the same second. Most mornings, the radio actually gets quiet."
    >
      <DriverTablet client:load />
    </FeatureRow>

    <FeatureRow
      eyebrow="Operations"
      title="Run the morning from one screen."
      body="Check-ins, status changes, and standby relays update the moment somebody acts on them, whether that's a driver in a van or a dispatcher at her desk. You stop answering the radio just to write things down; the board already knows."
      reverse
    >
      <DispatchTable client:load />
    </FeatureRow>

    <FeatureRow
      eyebrow="Routes"
      title="Plan every shift from one screen."
      body="Routes are grouped by district and color-coded the way dispatchers already think about them. When you reassign a driver, every screen in the office picks it up before the next radio call, so nobody has to remember to tell anyone."
    >
      <div class="grid grid-cols-2 gap-3">
        <RouteCard client:load routeNumber="AH-12" district="anoka" driver="Kathy R." vehicle="V-101" status="Covered" />
        <RouteCard client:load routeNumber="WBL-21" district="wbl" driver="Marcus T." vehicle="V-114" status="At-risk" />
        <RouteCard client:load routeNumber="NSP-04" district="northsp" driver="Devin O." vehicle="V-132" status="Covered" />
        <RouteCard client:load routeNumber="CST-02" district="cst" driver="—" vehicle="—" status="Open" />
      </div>
    </FeatureRow>

    <FeatureRow
      eyebrow="Coverage"
      title="Cover a no-show before the second call lands."
      body="When a driver calls in, eligible standby drivers show up at the top of the list, sorted by the district that needs them most. One click reassigns the route and writes the audit trail, so when somebody asks at 5 PM you can still tell them what you decided at 4:55."
      reverse
    >
      <CheckInGrid client:load />
    </FeatureRow>

    <FeatureRow
      eyebrow="Compliance"
      title="Pre-trip in the cab, audit-ready before the buses roll."
      body="Drivers run the 33-item check from the tablet, photos and all, and any defect they catch routes straight to compliance and maintenance the same second. When DOT walks in, all of it is one click away from the desk."
    >
      <ComplianceDiff client:load />
    </FeatureRow>

    <FeatureRow
      eyebrow="Detail"
      title="Every driver, van, and route is one click away."
      body="Slide-out timelines for everyone and everything, with activity, assignments, notes, and history laid out in the order they happened. It's the kind of context that used to live in somebody's head."
      reverse
    >
      <DrawerPreview client:load />
    </FeatureRow>

  </div>
</section>
